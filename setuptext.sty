\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{setuptext}[2026/04/15 Text Options]

% -------- SPACING --------
\raggedbottom % no vertical justification
\RequirePackage{calc} % setcounter / setlength / widthof
\RequirePackage{indentfirst} % force indent
% (must use before polyglossia/ragged2e)

\RequirePackage[normalem]{ulem} % uline uuline uwave sout xout dashuline dotuline
% \RequirePackage{censor} % censor censorbox blackout
% \StopCensoring % turn off censor


% -------- PAGE --------
\RequirePackage{lipsum, ragged2e} % minipage / raggedright

\RequirePackage{multicol} % page columns \begin{multicols*}{2} \columnbreak
% \setlength{\columnsep}{12pt}      % distance between columns
% \setlength{\columnseprule}{0.6pt} % thickness of vertical rule
% \def\columnseprulecolor{\color{blue}} % rule color

\RequirePackage{titling} % pretitle posttitle thetitle
\appendiargdef{\title}{% avoid clash with titlesec
  \begingroup
  \protected@xdef\titlename{#1}
\endgroup}
% \RequirePackage{titlesec} % modify title section
% \titlelabel{\thetitle.\quad}

\RequirePackage{pdfpages} % \includepdf[pages=-]{All.pdf}

% \RequirePackage{tramlines} % inter alia lines
% \RequirePackage{framed} % box around things with separated page
% \RequirePackage{tcolorbox} % colored box for examples and theorems
% \RequirePackage{shadowbox} %shadowbox, doublebox, ovalbox, Ovalbox and lines


% -------- EMOJI --------
% \RequirePackage{wasysym} % for emoji \smiley
%% http://xyoshiki.web.fc2.com/tex/wasysym.html

\RequirePackage{pifont} % Japanese emoji with item
%% \ding{37} \ding{38} \dingline{40}
%% \begin{dinglist}{48} \begin{dingautolist}{192}
%% http://xyoshiki.web.fc2.com/tex/zapfdingbats.html

\RequirePackage[names=false,preload-names=false]{bxcoloremoji} % colored emoji
%% \coloremoji{❤️} ~capof{1} ~fill{} ~line{}
%% \begin{~list}{✏️} \begin{~autolist}{♠️}
%% \pagenumbering{coloremojikeycap} 0-10 page number


% -------- REFERENCE --------
\RequirePackage[hidelinks]{hyperref} % link
\hypersetup{
   colorlinks=true,   % text coloring instead of boxes
   linkcolor=blue,    % internal links
   urlcolor=blue,     % web addresses \url
}

% \RequirePackage{cleverref} % ref section, figure
\RequirePackage{lastpage} % ref \pageref*{LastPage}

\RequirePackage{sidenotes} % add sidenote
% \RequirePackage{marginnote} % use instead of marginpar
\reversemarginpar % forces sidenotes to the left side


% -------- BIBLIOGRAPHY --------
% \usepackage[numbers,sort&compress]{natbib} % number + sort
% \usepackage[]{natbib}
% \bibliographystyle{apalike}

% \bibliography{<bib file>} % make references list


% -------- LIST --------
\RequirePackage{enumitem} % enum label
\RequirePackage{tasks} % vertically-aligned horizontal list


% -------- TABLE --------
\RequirePackage{hhline, colortbl} % table border
\RequirePackage[export]{adjustbox} % \begin{adjustbox}{width=\columnwidth,center} for scaling tabular
    % export allows valign=c option in \includegraphics inside tabular

% \RequirePackage{tabularx} % evenly spaced column X
% \RequirePackage{tabularray} % tlbr environment with colspec width hlines row{1-Z}

% \RequirePackage{longtable} % multipage table
% \RequirePackage{subcaption} % display subcaption in caption

\RequirePackage{array} % define column type C,L,R{<len>}
\newcommand{\PreserveBackslash}[1]{\let\temp=\\#1\let\\=\temp}
\newcolumntype{C}[1]{>{\PreserveBackslash\centering}p{#1}}
\newcolumntype{R}[1]{>{\PreserveBackslash\raggedleft}p{#1}}
\newcolumntype{L}[1]{>{\PreserveBackslash\raggedright}p{#1}}

\newcommand{\rowsep}[1]{\vphantom{\parbox[c]{0.5em}{{}\vspace{#1}{}}}} % \rowsep{2.1em}

\newcommand{\itemcolor}[1]{ % switch label color
  \renewcommand{\makelabel}[1]{\color{#1}\hfil ##1}
}


\endinput

